{
  "version": 2,
  "name": "attendance-system-backend",
  "builds": [
    {
      "src": "attendance-system/backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/users",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/attendance",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/attendance/(.*)",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/reports",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/reports/(.*)",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/qrcode",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/qrcode/(.*)",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "attendance-system/backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "attendance-system/backend/index.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://hesxkxbtreqfxmhrdwml.supabase.co",
    "SUPABASE_ANON_KEY": "sb_publishable_jTsJmSF195H4U6Og7oOdSA_2VI1_xnd",
    "SUPABASE_SERVICE_KEY": "sb_secret_2KcpN......",
    "PORT": "3000",
    "NODE_ENV": "production"
  },
  "functions": {
    "attendance-system/backend/index.js": {
      "includeFiles": "attendance-system/backend/**",
      "excludeFiles": "attendance-system/backend/node_modules/.cache/**"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization"
        }
      ]
    }
  ]
}